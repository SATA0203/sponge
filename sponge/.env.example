# Sponge Configuration

# Application
APP_NAME=Sponge
DEBUG=True
VERSION=0.1.0

# Server
HOST=0.0.0.0
PORT=8000

# LLM Configuration
# Set your API key here or use the default mock mode for testing
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-test-key-for-development-only
ANTHROPIC_API_KEY=
MODEL_NAME=gpt-4o
TEMPERATURE=0.7
MAX_TOKENS=4096

# Database
DATABASE_URL=postgresql://sponge:sponge_password@localhost:5432/sponge_db
DB_POOL_SIZE=10
DB_ECHO=False

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Sandbox
SANDBOX_ENABLED=True
SANDBOX_TYPE=docker
SANDBOX_TIMEOUT=300
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0

# Security
SECRET_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
