```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled and build artifacts
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out

# Dependencies
.venv/
venv/
env/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# Editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db
```